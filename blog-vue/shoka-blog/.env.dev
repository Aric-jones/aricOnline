VITE_SERVICE_BASE_URL=http://localhost:9000

# 第三方登录回调地址（本地测试时使用内网穿透地址）
# 使用 ngrok: VITE_OAUTH_REDIRECT_BASE=https://abc123.ngrok-free.app
# 使用 natapp: VITE_OAUTH_REDIRECT_BASE=http://abc123.natapp1.cc
# 不配置则默认使用: http://127.0.0.1:1314（仅用于开发，第三方平台无法回调）
VITE_OAUTH_REDIRECT_BASE=http://127.0.0.1:1314
